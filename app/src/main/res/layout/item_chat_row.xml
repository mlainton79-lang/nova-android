<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="4dp"
    android:paddingEnd="12dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:background="?attr/selectableItemBackground">

    <View
        android:id="@+id/chatRowActiveIndicator"
        android:layout_width="2dp"
        android:layout_height="match_parent"
        android:layout_marginEnd="12dp"
        android:background="#00D4FF" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/chatRowTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#EEEEFF"
            android:letterSpacing="0.01"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/chatRowPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#555570"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="3dp" />

    </LinearLayout>

    <TextView
        android:id="@+id/chatRowTimestamp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="10sp"
        android:textColor="#333355"
        android:layout_marginStart="8dp"
        android:layout_gravity="top" />

</LinearLayout>
