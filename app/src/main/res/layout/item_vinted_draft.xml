<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/nova_surface2">

    <TextView
        android:id="@+id/draftItemTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Draft title"
        android:textColor="@color/nova_text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/draftItemAge"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="4dp"
        android:text="Saved draft"
        android:textColor="@color/nova_text_dim"
        android:textSize="13sp" />

</LinearLayout>
