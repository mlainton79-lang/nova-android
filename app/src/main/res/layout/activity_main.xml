<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/menuButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/icon_button_bg"
                android:contentDescription="Open menu"
                android:padding="10dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:tint="#231B34" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <TextView
                    android:id="@+id/titleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nova"
                    android:textColor="#FFFFFF"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/subtitleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Assistant identity: Tony"
                    android:textColor="#D6D0E2"
                    android:textSize="16sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/brainPillText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/brain_pill_bg"
                android:paddingStart="12dp"
                android:paddingTop="8dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp"
                android:text="OpenAI"
                android:textColor="#231B34"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#EFEFEF"
            android:paddingStart="10dp"
            android:paddingTop="8dp"
            android:paddingEnd="10dp"
            android:paddingBottom="8dp"
            android:text="Tony is ready."
            android:textColor="#2A2238"
            android:textSize="13sp"
            android:layout_marginBottom="8dp" />

        <ScrollView
            android:id="@+id/chatScrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#0F0B17"
            android:padding="8dp"
            android:scrollbars="vertical">

            <LinearLayout
                android:id="@+id/chatContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

        <ImageView
            android:id="@+id/photoPreview"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="#1A1A1A"
            android:contentDescription="Camera preview"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/composerRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/composer_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="8dp">

            <ImageButton
                android:id="@+id/plusButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/icon_button_bg"
                android:contentDescription="More actions"
                android:padding="10dp"
                android:src="@android:drawable/ic_input_add"
                android:tint="#231B34" />

            <EditText
                android:id="@+id/inputText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:background="@android:color/transparent"
                android:hint="Message Tony..."
                android:textColor="#FFFFFF"
                android:textColorHint="#8E86A1"
                android:maxLines="4"
                android:minLines="1"
                android:padding="6dp"
                android:textSize="18sp" />

            <ImageButton
                android:id="@+id/micButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/icon_button_bg"
                android:contentDescription="Voice input"
                android:padding="10dp"
                android:src="@android:drawable/ic_btn_speak_now"
                android:tint="#231B34" />

            <ImageButton
                android:id="@+id/sendButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/icon_button_bg"
                android:contentDescription="Send"
                android:padding="10dp"
                android:src="@android:drawable/ic_menu_send"
                android:tint="#231B34" />
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/drawerPanel"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@drawable/drawer_panel_bg"
        android:orientation="vertical">

        <Button
            android:id="@+id/drawerNewChatButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="+ New chat"
            android:textAllCaps="false"
            android:layout_margin="12dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/chatListRecycler"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFFFFF"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp" />

        <Button
            android:id="@+id/drawerBrainButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Choose brain"
            android:textAllCaps="false"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/drawerTasksButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Open task list"
            android:textAllCaps="false"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/drawerSaveTaskButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save current text as task"
            android:textAllCaps="false"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/drawerMemoryButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="View home memory"
            android:textAllCaps="false"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/drawerTonyMemoryButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tony's memory"
            android:textAllCaps="false"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/drawerClearChatButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Clear chat"
            android:textAllCaps="false"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/drawerSyncCodebaseButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sync codebase to Tony"
            android:textAllCaps="false"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/drawerCloseButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Close menu"
            android:textAllCaps="false"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="12dp" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>